# Copy to .env and adjust. All variables have sensible defaults —
# the server runs fine without any of them set.

# Listen address
ADDR=:8080

# "dev" = templates/static read from disk on every request (live reload)
# "prod" = everything served from the embedded filesystem
ENV=dev

# Path to the SQLite database file
DB_PATH=data/app.db

# Fallback language (must have a matching locales/<lang>.json)
DEFAULT_LANG=en
